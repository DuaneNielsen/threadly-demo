# Closed-Loop Remediation Demo Configuration
# Copy to .env and adjust for your environment:
#   cp .env.example .env

# --- Server ---
PORT=5000
COOLDOWN=60

# --- Paths (relative to this directory, or absolute) ---
BUILDS_DIR=../builds
PETCLINIC_DIR=../spring-petclinic

# --- PetClinic App ---
APP_PORT=8180
PETCLINIC_LOG=/tmp/petclinic.log
PETCLINIC_STDOUT_LOG=/tmp/petclinic-stdout.log

# --- Claude ---
CLAUDE_LOG=/tmp/claude-sre.log

# --- Simulated Alarm ---
DEMO_HOST=thor
