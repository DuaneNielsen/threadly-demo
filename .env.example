# Closed-Loop Remediation Demo Configuration
# Copy to .env and adjust for your environment:
#   cp .env.example .env

# --- Server ---
PORT=5000
COOLDOWN=60

# --- Paths (relative to this directory, or absolute) ---
BUILDS_DIR=../threadly/builds
APP_DIR=../threadly

# --- Demo App ---
APP_NAME=Threadly
APP_PORT=8180
APP_JAR_NAME=threadly.jar
APP_LOG=/tmp/threadly.log
APP_STDOUT_LOG=/tmp/threadly-stdout.log
# Spring profile. Leave empty for default (PostgreSQL — needs docker compose up in ../threadly/).
# Set to `h2` for embedded H2 in-memory DB (no extra tier required).
APP_PROFILES=h2

# --- Claude ---
CLAUDE_LOG=/tmp/claude-sre.log

# --- UI ---
DEMO_TITLE="Threadly Closed-Loop Remediation"

# --- Simulated Alarm ---
DEMO_HOST=thor
