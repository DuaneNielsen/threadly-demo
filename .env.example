# Closed-Loop Remediation Demo Configuration
# Copy to .env and adjust for your environment:
#   cp .env.example .env

# --- Server ---
PORT=5000
COOLDOWN=60

# --- Paths (relative to this directory, or absolute) ---
BUILDS_DIR=../threadly/builds
APP_DIR=../threadly

# --- Demo App ---
APP_NAME=Threadly
APP_PORT=8180
APP_JAR_NAME=threadly.jar
APP_LOG=/tmp/threadly.log
APP_STDOUT_LOG=/tmp/threadly-stdout.log
# SQLite DB file. State persists across deploys; delete the file for a clean slate.
THREADLY_DB=/tmp/threadly.db

# --- Payment Service (threadly-payments) ---
PAYMENTS_DIR=../threadly-payments
PAYMENTS_BUILDS_DIR=../threadly-payments/builds
PAYMENTS_NAME=ThreadlyPayments
PAYMENTS_PORT=8181
PAYMENTS_JAR_NAME=threadly-payments.jar
PAYMENTS_LOG=/tmp/payments.log
PAYMENTS_STDOUT_LOG=/tmp/payments-stdout.log
PAYMENTS_URL=http://localhost:8181
# SQLite DB file for payments
PAYMENTS_DB=/tmp/payments.db

# --- Claude ---
CLAUDE_LOG=/tmp/claude-sre.log

# --- UI ---
DEMO_TITLE="Threadly Closed-Loop Remediation"

# --- Simulated Alarm ---
DEMO_HOST=thor
